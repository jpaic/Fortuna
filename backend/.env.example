# Neon PostgreSQL connection string (get this from the Neon dashboard)
DATABASE_URL=postgresql://user:password@ep-example.neon.tech/financial_platform?sslmode=require

# JWT secrets — use long, random, distinct values in production
JWT_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Resend (transactional email for verification + password reset)
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=Ledger <no-reply@yourdomain.com>

# CORS: the deployed frontend origin
FRONTEND_URL=http://localhost:5173

# Vercel cron secret (set in Vercel dashboard, used to protect /api/cron/* endpoints)
CRON_SECRET=replace-with-a-long-random-string

PORT=4000
NODE_ENV=development
